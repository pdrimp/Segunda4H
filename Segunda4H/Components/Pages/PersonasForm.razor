@page "/personas/nueva"
@page "/personas/editar/{Id:int}"
@using System.Threading.Tasks
@rendermode InteractiveServer
@inject IRepositorioPersonas Repositorio
@inject IRepositorioClasificaciones RepositorioClasificaciones
@inject IRepositorioHabitos RepositorioHabitos
@inject NavigationManager Navigation

@if (_error)
{
    <div class="alert alert-danger">
        <h2>La persona que intenta editar no se encuentra registrada</h2>
    </div>
    <button class="btn btn-danger" @onclick="Regresar">Regresar</button>
}
else
{
    <EditForm Model="_persona" FormName="frmPersona" OnValidSubmit="Guardar">
        <DataAnnotationsValidator />
        <div class="row align-items-center">
            <div class="col col-2">
                <label for="txtNombre" class="col-form-label">Nombre</label>
            </div>
            <div class="col col-10">
                <InputText class="form-control" id="txtNombre" @bind-Value="_persona.Nombre" />
                <ValidationMessage For="@(() => _persona.Nombre)" />
            </div>
        </div>
        <div class="row mt-3 align-items-center">
            <div class="col col-2">
                <label for="txtCorreo" class="col-form-label">Correo</label>
            </div>
            <div class="col col-10">
                <InputText class="form-control" id="txtCorreo" @bind-Value="_persona.Correo" />
                <ValidationMessage For="@(() => _persona.Correo)" />
            </div>
        </div>
        <div class="row mt-3 align-items-center">
            <div class="col col-2">
                <label for="txtTelefono" class="col-form-label">Teléfono</label>
            </div>
            <div class="col col-10">
                <InputText class="form-control" id="txtTelefono" @bind-Value="_persona.Telefono" />
                <ValidationMessage For="@(() => _persona.Telefono)" />
            </div>
        </div>
        <div class="row mt-3 align-items-center">
            <div class="col col-2">
                <label class="col-form-label">Género</label>
            </div>
            <div class="col col-10">
                <InputRadioGroup TValue="string" @bind-Value="_persona.Genero">
                    <div class="form-check form-check-inline">
                        <InputRadio TValue="string" Value="@("Femenino")" class="form-check-input" id="rFemenino" />
                        <label class="form-check-label" for="rFemenino">Femenino</label>
                    </div>
                    <div class="form-check form-check-inline">
                        <InputRadio TValue="string" Value="@("Masculino")" class="form-check-input" id="rMasculino" />
                        <label class="form-check-label" for="rMasculino">Masculino</label>
                    </div>
                    <div class="form-check form-check-inline">
                        <InputRadio TValue="string" Value="@("Otro")" class="form-check-input" id="rOtro" />
                        <label class="form-check-label" for="rOtro">Otro</label>
                    </div>
                </InputRadioGroup>
                <ValidationMessage For="@(() => _persona.Genero)" />
            </div>
        </div>
        <div class="row mt-3 align-items-center">
            <div class="col col-2">
                <label for="ddlClasificacion" class="col-form-label">Clasificación</label>
            </div>
            <div class="col col-10 ">
                <InputSelect class="form-select" id="ddlClasificacion" @bind-Value="_persona.ClasificacionId">
                    <option value="">Seleccione una clasificación</option>
                    @foreach (var clasificacion in _clasificaciones)
                    {
                        <option value="@clasificacion.Id">@clasificacion.Nombre</option>
                    }
                </InputSelect>
                <ValidationMessage For="@(() => _persona.ClasificacionId)" />
            </div>

            <!-- Hábitos (checkboxes) -->
            <div class="row mt-3 align-items-start">
                <div class="col-2">
                    <label class="col-form-label">Hábitos</label>
                </div>
                <div class="col-10">
                    @if (_habitos != null && _habitos.Any())
                    {
                        <div class="d-flex flex-wrap">
                            @foreach (var h in _habitos)
                            {
                                <div class="form-check me-3">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           id="habito_@h.Id"
                                           checked="@IsHabitoSelected(h.Id)"
                                           @onchange="(ChangeEventArgs e) => OnHabitoChanged(h.Id, Convert.ToBoolean(e.Value))" />
                                    <label class="form-check-label" for="habito_@h.Id">@h.Nombre</label>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-muted">No hay hábitos disponibles.</div>
                    }
                </div>
            </div>

            <div class="row mt-3">
                <div class="col">
                    <button class="btn btn-primary me-3" type="submit">Guardar</button>
                    <button class="btn btn-danger" @onclick="Regresar">Cancelar</button>
                </div>
            </div>
        </div>
    </EditForm>
}

@code {
    [Parameter]
    public int Id { get; set; }
    private Persona _persona = new();
    private bool _error = false;
    private List<Clasificacion> _clasificaciones = new();
    private List<Habito> _habitos = new();
    private List<int> _habitosSeleccionados = new();


    protected override async Task OnInitializedAsync()
    {
        _clasificaciones = await RepositorioClasificaciones.ObtenerClasificaciones();
        _habitos = await RepositorioHabitos.ObtenerHabitos();

        if (Id > 0)
        {
            // Cargar la persona existente para editar
            var persona = await Repositorio.ObtenerPersonaPorId(Id);
            if (persona != null)
            {
                _persona = persona;
                if (persona.Habitos is not null)
                {
                    _habitosSeleccionados = persona.Habitos.Select(_ => _.Id).ToList();
                }
            }
            else
            {
                _error = true;
            }
        }
    }

    private async Task Guardar()
    {
        // Sincronizar la colección de hábitos de la persona con los IDs seleccionados
        _persona.Habitos = _habitos.Where(h => _habitosSeleccionados.Contains(h.Id)).ToList();

        if (Id > 0)
        {
            await Repositorio.ActualizarPersona(Id, _persona);
        }
        else
        {
            await Repositorio.AgregarPersona(_persona);
        }
        Navigation.NavigateTo("/personas");
    }

    private void Regresar()
    {
        Navigation.NavigateTo("/personas");
    }

    private void OnHabitoChanged(int habitoId, bool isChecked)
    {
        if (isChecked)
        {
            if (!_habitosSeleccionados.Contains(habitoId))
                _habitosSeleccionados.Add(habitoId);
        }
        else
        {
            if (_habitosSeleccionados.Contains(habitoId))
                _habitosSeleccionados.Remove(habitoId);
        }
    }

    private bool IsHabitoSelected(int id) => _habitosSeleccionados.Contains(id);
}
